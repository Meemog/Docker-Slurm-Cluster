#!/bin/bash

PROJECT_NAME=slightly-less-of-a-cluster

MEM=512
NODES=2
MODULE=ENV

# Parse flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    -m)
      MEM="$2"
      shift 2
      ;;
    --mem=*)
      MEM="${1#*=}"
      shift
      ;;
    -n)
      NODES="$2"
      shift 2
      ;;
    --nodes=*)
      NODES="${1#*=}"
      shift
      ;;
    --lmod)
      MODULE="LMOD"
      shift
      ;;
    -h|--help)
      echo "Usage: $0 [-m memory|--mem=memory] [-n nodes|--nodes=nodes] [--lmod]"
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      echo "Usage: $0 [-m memory|--mem=memory] [-n nodes|--nodes=nodes] [--lmod]"
      exit 1
      ;;
  esac
done

MEM_LIMIT="${MEM}m"

echo "removing old containers"
docker compose -p $PROJECT_NAME down -v --remove-orphans --rmi all > /dev/null 2>&1

echo "generating docker-compose.yml"
cat > docker-compose.yml <<EOF
services:
  login:
    build: .
    container_name: login
    hostname: login
    ports:
      - "2222:22"
    environment:
      ROLE: login
      MODULE_FRAMEWORK: $MODULE
    volumes:
      - home:/home/dev
      - ./cluster_key:/home/dev/.ssh/id_ed25519:ro
      - ./authorized_keys:/home/dev/.ssh/authorized_keys:ro
      - ./slurm.conf:/etc/slurm/slurm.conf:ro
      - ./munge.key:/tmp/munge.key:ro
      - ./setup_files:/home/dev/setup_files:ro
    networks:
      - cluster
EOF

for i in $(seq 1 "$NODES"); do
cat >> docker-compose.yml <<EOF

  node$i:
    build: .
    container_name: node$i
    hostname: node$i
    mem_limit: $MEM_LIMIT
    environment:
      ROLE: compute
      MODULE_FRAMEWORK: $MODULE
    volumes:
      - home:/home/dev
      - ./authorized_keys:/home/dev/.ssh/authorized_keys:ro
      - ./slurm.conf:/etc/slurm/slurm.conf:ro
      - ./munge.key:/tmp/munge.key:ro
      - ./setup_files:/home/dev/setup_files:ro
    networks:
      - cluster
EOF
done

cat >> docker-compose.yml <<EOF

volumes:
  home:

networks:
  cluster:
    driver: bridge
EOF

echo "generating slurm.conf"
cat > slurm.conf <<EOF
ClusterName=cluster

SlurmUser=slurm

AuthType=auth/munge
SlurmctldHost=login

ProctrackType=proctrack/pgid
TaskPlugin=task/none
JobAcctGatherType=jobacct_gather/none

SchedulerType=sched/backfill
SelectType=select/cons_tres
SelectTypeParameters=CR_Core

StateSaveLocation=/slurm/state
SlurmdSpoolDir=/slurm/spool

NodeName=login State=DOWN
NodeName=node[1-${NODES}] CPUs=4 RealMemory=${MEM} State=UNKNOWN
PartitionName=debug Nodes=node[1-${NODES}] Default=YES MaxTime=INFINITE State=UP
EOF

echo "generating munge.key"
dd if=/dev/urandom of=./munge.key bs=1 count=1024 status=none

echo "generating ssh keys"
rm -f cluster_key cluster_key.pub
ssh-keygen -t ed25519 -C "" -f cluster_key -N "" > /dev/null
cat cluster_key.pub > authorized_keys

echo "building containers"
docker compose -p $PROJECT_NAME up --build --force-recreate