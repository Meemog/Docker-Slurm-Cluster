#!/bin/bash

PROJECT_NAME=slightly-less-of-a-cluster

MEM=512
NODES=2
MODULE=NONE
DATABASE=false

# Parse flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    -m)
      MEM="$2"
      shift 2
      ;;
    --mem=*)
      MEM="${1#*=}"
      shift
      ;;
    -n)
      NODES="$2"
      shift 2
      ;;
    --nodes=*)
      NODES="${1#*=}"
      shift
      ;;
    --module=*)
      value="${1#*=}"

      case "${value,,}" in
        lmod)
          MODULE="LMOD"
          ;;
        env)
          MODULE="ENV"
          ;;
        *)
          echo "Invalid module: $value"
          echo "Valid values are: lmod or env"
          exit 1
          ;;
      esac
      shift
      ;;
    --database)
      DATABASE=true
      shift
      ;;
    -h|--help)
      echo "Usage: $0 [-m memory|--mem=memory] [-n nodes|--nodes=nodes] [--lmod] [--database]"
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      echo "Usage: $0 [-m memory|--mem=memory] [-n nodes|--nodes=nodes] [--lmod] [--database]"
      exit 1
      ;;
  esac
done

MEM_LIMIT="${MEM}m"

echo "removing old containers"
docker compose -p $PROJECT_NAME down -v --remove-orphans --rmi all > /dev/null 2>&1

echo "generating ssh keys"

rm -f cluster_key cluster_key.pub
ssh-keygen -t ed25519 -C "Generated by cluster-build" -f cluster_key -N "" > /dev/null
cat cluster_key.pub > authorized_keys

echo "generating host keys"

rm -rf hostkeys
mkdir hostkeys

for host in login $(seq -f "node%.0f" 1 "$NODES"); do
    ssh-keygen -q -t ed25519 \
        -N "" -C "Generated By cluster-build" \
        -f "hostkeys/${host}_ssh_host_ed25519_key"
done

rm -f known_hosts

for host in login $(seq -f "node%.0f" 1 "$NODES"); do
    printf "%s " "$host" >> known_hosts
    cat "hostkeys/${host}_ssh_host_ed25519_key.pub" >> known_hosts
done

echo "generating docker-compose.yml"
cat > docker-compose.yml <<EOF
services:

  login:
    build: .
    image: generic-node
    container_name: login
    hostname: login
    ports:
      - "2222:22"
    environment:
      ROLE: login
      MODULE_FRAMEWORK: $MODULE
    volumes:
      - home:/home/dev

      - ./cluster_key:/home/dev/.ssh/id_ed25519:ro
      - ./authorized_keys:/home/dev/.ssh/authorized_keys:ro
      - ./known_hosts:/home/dev/.ssh/known_hosts:ro
      - ./hostkeys/login_ssh_host_ed25519_key:/etc/ssh/ssh_host_ed25519_key:ro
      - ./hostkeys/login_ssh_host_ed25519_key.pub:/etc/ssh/ssh_host_ed25519_key.pub:ro

      - ./munge.key:/tmp/munge.key:ro

      - ./conf/slurm.conf:/tmp/conf/slurm.conf:ro
EOF

if [[ "$DATABASE" == true ]]; then
cat >> docker-compose.yml <<EOF
      - ./conf/slurmdbd.conf:/tmp/conf/slurmdbd.conf:ro
EOF
fi

if [[ "$MODULE" == "ENV" ]]; then
cat >> docker-compose.yml <<EOF

      - ./setup_files/environment-modules.sh:/tmp/setup_files/environment-modules.sh:ro
EOF
elif [[ "$MODULE" == "LMOD" ]]; then
cat >> docker-compose.yml <<EOF

      - ./setup_files/lmod-modules.sh:/tmp/setup_files/lmod-modules.sh:ro
EOF
fi

cat >> docker-compose.yml <<EOF
    networks:
      - cluster
EOF

for i in $(seq 1 "$NODES"); do
cat >> docker-compose.yml <<EOF

  node$i:
    image: generic-node
    container_name: node$i
    hostname: node$i
    mem_limit: $MEM_LIMIT
    environment:
      ROLE: compute
      MODULE_FRAMEWORK: $MODULE
    volumes:
      - home:/home/dev

      - ./authorized_keys:/home/dev/.ssh/authorized_keys:ro
      - ./known_hosts:/home/dev/.ssh/known_hosts:ro
      - ./hostkeys/node${i}_ssh_host_ed25519_key:/etc/ssh/ssh_host_ed25519_key:ro
      - ./hostkeys/node${i}_ssh_host_ed25519_key.pub:/etc/ssh/ssh_host_ed25519_key.pub:ro

      - ./munge.key:/tmp/munge.key:ro

      - ./conf/slurm.conf:/tmp/conf/slurm.conf:ro
EOF
if [[ "$MODULE" == "ENV" ]]; then
cat >> docker-compose.yml <<EOF

      - ./setup_files/environment-modules.sh:/tmp/setup_files/environment-modules.sh:ro
EOF
elif [[ "$MODULE" == "LMOD" ]]; then
cat >> docker-compose.yml <<EOF

      - ./setup_files/lmod-modules.sh:/tmp/setup_files/lmod-modules.sh:ro
EOF
fi
cat >> docker-compose.yml <<EOF
    networks:
      - cluster
EOF
done


if [[ "$DATABASE" == true ]]; then
cat >> docker-compose.yml <<EOF

  database:
    image: generic-node
    container_name: database
    hostname: database
    environment:
      ROLE: database
      MODULE_FRAMEWORK: $MODULE
    volumes:
      - ./conf:/tmp/conf:ro
      - ./munge.key:/tmp/munge.key:ro
      - ./setup_files/database.sh:/tmp/setup_files/database.sh:ro
    networks:
      - cluster
EOF
fi

cat >> docker-compose.yml <<EOF

volumes:
  home:

networks:
  cluster:
    driver: bridge
EOF

echo "generating configs"
mkdir -p conf

echo "generating slurm.conf"
cat > conf/slurm.conf <<EOF
ClusterName=cluster

SlurmUser=slurm

AuthType=auth/munge
SlurmctldHost=login
EOF

if [[ "$DATABASE" == true ]] ; then
cat >> conf/slurm.conf <<EOF

AccountingStorageType=accounting_storage/slurmdbd
AccountingStorageHost=database
EOF
fi

cat >> conf/slurm.conf <<EOF

ProctrackType=proctrack/pgid
TaskPlugin=task/none
JobAcctGatherType=jobacct_gather/none

SchedulerType=sched/backfill
SelectType=select/cons_tres
SelectTypeParameters=CR_Core

StateSaveLocation=/slurm/state
SlurmdSpoolDir=/slurm/spool

NodeName=login State=DOWN
NodeName=node[1-${NODES}] CPUs=4 RealMemory=${MEM} State=UNKNOWN
PartitionName=debug Nodes=node[1-${NODES}] Default=YES MaxTime=INFINITE State=UP
EOF

if [[ "$DATABASE" == true ]]; then
echo "generating database daemon config"

cat > conf/slurmdbd.conf <<EOF
AuthType=auth/munge

SlurmUser=slurm

DbdHost=database
DbdPort=6819

StorageType=accounting_storage/mysql

StorageHost=localhost
StorageUser=slurm
StoragePass=password
StorageLoc=slurm_acct_db

LogFile=/var/log/slurm/slurmdbd.log
PidFile=/run/slurmdbd.pid

DebugLevel=info
EOF
fi

echo "generating munge.key"
dd if=/dev/urandom of=./munge.key bs=1 count=1024 status=none

echo "building containers"
docker compose -p $PROJECT_NAME up --build